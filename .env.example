# ============================================================
#  KusoNime — Pengaturan Website (CONTOH)
#  Salin file ini menjadi .env dan isi nilai yang sesuai.
# ============================================================

# --- API ---
VITE_API_BASE=https://api-example.vercel.app

# --- Identitas Situs ---
VITE_SITE_NAME=KusoNime
VITE_SITE_TAGLINE=Watch Anime Free
VITE_SITE_DESCRIPTION=Stream anime online for free in HD. Watch trending, popular and new anime.
VITE_SITE_URL=https://kusonimeid.vercel.app

# --- Tampilan / Branding ---
VITE_ACCENT_COLOR=#e85d26
VITE_ACCENT_COLOR2=#f97316
VITE_BG_COLOR=#080c14

# --- Spotlight Hero ---
VITE_SPOTLIGHT_COUNT=6
VITE_SPOTLIGHT_INTERVAL=6000

# --- Pencarian ---
VITE_SEARCH_SUGGESTIONS=6
VITE_SEARCH_DEBOUNCE=300

# --- Footer ---
VITE_FOOTER_TEXT=KusoNime · Powered by Miruro API · For educational purposes only
VITE_API_LINK=https://api-example.vercel.app
